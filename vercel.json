{
  "functions": {
    "server.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/products(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/orders(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    }
  ]
}